-- Parte 1: Explorando o INNER JOIN
/*1. Liste o nome do produto, o nome do fornecedor e o país do fornecedor para
todos os produtos da categoria 2.*/

SELECT products.ProductName AS 'Nome Produto',
suppliers.SupplierName AS 'Nome Fornecedor',
suppliers.Country AS 'Pais'
FROM products
INNER JOIN suppliers ON
products.ProductID = suppliers.SupplierID
WHERE categoryID=2;


/*2. Exiba o ID do pedido, a data do pedido e o nome da transportadora
responsável por cada entrega.*/

SELECT orders.orderid AS 'IDpedido',
orders.OrderDate AS 'DataPedido',
shippers.ShipperName AS 'NomeTransportadora'
FROM orders
INNER JOIN shippers ON
orders.ShipperID = shippers.ShipperID;


/*3. Mostre o nome do produto e o nome da cidade do fornecedor para
produtos que custam mais de 50 unidades monetárias.*/
SELECT products.ProductName AS 'NomeProduto',
suppliers.Country AS 'Pais'
FROM products
INNER JOIN suppliers ON
products.supplierid = suppliers.SupplierID
WHERE Price>50;


/* 4. Relacione todos os pedidos (Orders) feitos, mostrando o ID do pedido e o
nome da transportadora, filtrando apenas para a transportadora 'Speedy
Express'.*/

SELECT orders.OrderID AS 'IDpedido',
shippers.ShipperName AS 'NomeTransportadora'
FROM orders
INNER JOIN shippers ON
orders.ShipperID = shippers.ShipperID
WHERE ShipperName LIKE '%Speedy%';


/*5. Liste os nomes dos produtos e os nomes de seus respectivos
fornecedores, mas apenas para fornecedores localizados no 'Brazil' ou
'USA'.*/

SELECT products.ProductName AS 'NomeProduto', 
suppliers.SupplierName AS 'NomeFornecedor',
suppliers.country
FROM products
INNER JOIN suppliers ON
products.SupplierID = suppliers.SupplierID
WHERE suppliers.Country IN ('USA','Brazil');


