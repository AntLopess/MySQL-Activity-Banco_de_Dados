EX(16)
SELECT
City AS 'Cidade',
COUNT(*) AS Quantidade
FROM Customers
GROUP BY City
LIMIT 2;

EX(17)
SELECT supplierid AS 'IDFornecedor',
COUNT(*) AS TotalProdutos
FROM Products
GROUP BY SupplierID
LIMIT 5;

EX(18)
SELECT orderdate AS 'DataPedido',
COUNT(*) AS 'TotalEncomendas'
FROM Orders
GROUP BY orderdate
ORDER BY TotalEncomendas DESC
LIMIT 10;

EX(19)
SELECT customername AS 'NomeCliente',
postalCode AS 'CodigoPostal',
COUNT(*) AS TotalDeClientes
FROM Customers
GROUP BY PostalCode
ORDER BY TotalDeClientes DESC
LIMIT 8;

EX(20)
SELECT COUNT(DISTINCT CategoryID) AS TotalCategorias
FROM Products;
