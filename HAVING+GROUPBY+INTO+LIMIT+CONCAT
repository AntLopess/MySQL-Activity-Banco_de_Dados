FROM Suppliers
WHERE Suppliers.supplierid = Products.supplierid) AS 'NomedoFornecedor',
COUNT(*) AS 'QuantidadeDeProdutos'
FROM Products
GROUP BY supplierid
HAVING COUNT(*) < 5
ORDER BY QuantidadeDeProdutos DESC;

EX(28)
SELECT QuantidadeDeProdutos,
COUNT(*) AS NumeroDeCategorias
FROM (SELECT categoryid, COUNT(*) AS QuantidadeDeProdutos
FROM Products
GROUP BY CategoryID) AS ContagemCategorias
GROUP BY QuantidadeDeProdutos
HAVING COUNT(*) > 1;

