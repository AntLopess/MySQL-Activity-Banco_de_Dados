EX(6)
SELECT CONCAT (customername,' , ',city) AS 'NomeCliente e Cidade'
FROM Customers
LIMIT 12;

EX(7)
SELECT quantity AS 'Quantidade',
(100 - quantity) AS 'Diferenca'
FROM OrderDetails
LIMIT 20;

EX(8)
SELECT CONCAT (categoryname,' - ',description) AS 'NomeCategoria - Descricao'
FROM Categories
LIMIT 5;

EX(9)
SELECT (SELECT suppliername
FROM Suppliers
WHERE Suppliers.supplierid = Products.supplierid) AS 'NomeFornecedor',
productname AS 'NomeProduto',
price*50 AS '(Custo de 50 Unidades)'
FROM Products
LIMIT 10;

EX(10)
SELECT customername AS 'NomeCliente',
CONCAT(address,', ',city,', ',postalcode) AS 'Morada Completa'
FROM Customers
LIMIT 25;

