/*1. (Subquery no WHERE, LIMIT): Selecione o nome do produto e o seu preço,
mas apenas para os produtos que custam mais do que a média de preço de
todos os produtos do sistema. Limite a 15 resultados.*/

SELECT productName AS 'NomeProduto',
price AS 'Preco'
FROM products
WHERE price > (SELECT AVG(price)
FROM products)
LIMIT 15;


/*2. (Subquery no WHERE, CONCAT, LIMIT): Concatene o apelido e o nome
(LastName, FirstName) dos funcionários que nasceram antes do
funcionário mais novo da empresa (subquery para buscar a data máxima
de nascimento). Limite aos 5 primeiros.*/

SELECT CONCAT(Lastname,' ',firstname) AS 'NomeFuncionario'
FROM employees
WHERE BirthDate < (SELECT MAX(birthdate)
FROM employees)
LIMIT 5;


/*3. (Subquery no SELECT, Cálculos, LIMIT): Apresente o ProductName, o
Price e uma terceira coluna calculada por uma subquery que traga o preço
médio da sua respectiva categoria (CategoryID). Limite a 10 resultados.*/

SELECT productname AS 'Nomeproduto',
price AS 'Preco',
(SELECT FORMAT(AVG(price),2)
FROM products AS preco2
WHERE preco2.CategoryID = preco1.CategoryID) AS 'MediaDaCategoria'
FROM products AS preco1
LIMIT 10;


/*4. (Subquery no WHERE, CONCAT): Crie uma lista concatenando o nome do
cliente e o país, mas apenas para os clientes que residem no mesmo país
do fornecedor com SupplierID = 1 (obtenha este país via subquery).*/

SELECT CONCAT(customername,' - ',Country) AS 'Nome e Pais do Cliente'
FROM customers
WHERE Country = (SELECT Country
FROM Suppliers
WHERE supplierid = 1);

/*5. (Subquery no WHERE, Cálculos, LIMIT): Selecione os produtos onde o
valor calculado do seu stock hipotético (Price * 10) seja inferior ao preço do
produto mais caro da tabela. Limite a 12 registos.*/

SELECT productname AS 'NomeProduto',
FORMAT(price,2)AS 'Preco',
FORMAT(price*10,2)AS 'PrecoHipotetico'
FROM products
WHERE price*10<(SELECT MAX(price)
FROM products)
LIMIT 12;

/*6. (Subquery no SELECT, CONCAT, LIMIT): Liste os 8 primeiros clientes e,
numa coluna extra, concatene "Última compra em: " com a data da última
encomenda (OrderDate) que esse cliente realizou (subquery
correlacionada na tabela Orders).*/

SELECT customername AS 'NomeCliente',
CONCAT('Ultima Compra em: ',(SELECT MAX(orderdate)
FROM orders
WHERE orders.customerid = customers.customerid)) AS 'UltimaCompra'
FROM customers
LIMIT 8;

/*7. (Subquery no WHERE, LIMIT): Apresente os detalhes da encomenda
(OrderDetailID, Quantity) onde a quantidade solicitada seja exatamente
igual à quantidade máxima já registada em qualquer encomenda na tabela.
Limite a 5.*/

SELECT OrderdetailID AS 'IDdetalhedePedido',
quantity AS 'Quantidade'
FROM orderdetails
WHERE quantity = (SELECT MAX(quantity)
FROM orderdetails)
LIMIT 5;

/*8. (Subquery no WHERE, CONCAT, LIMIT): Concatene o nome da
transportadora (ShipperName) e o telefone. Exiba apenas aquelas que já
realizaram entregas para o cliente de CustomerID = 4 (busque os ShipperID
nas Orders via subquery). Limite a 3.*/

SELECT CONCAT(shippername,' - ',phone) AS 'Transportadora e Telefone'
FROM shippers
WHERE shipperid IN (SELECT shipperid
FROM Orders
WHERE customerid = 4)
LIMIT 3;

/*9. (Subquery no FROM/Derived Table, Cálculos): A partir de uma subquery
no FROM que calcule o preço com 20% de desconto para todos os
produtos, selecione o nome do produto e o novo preço apenas daqueles
que o novo preço ainda seja superior a 50. Limite a 10.*/

SELECT productname AS 'NomeProduto',
precocomdesconto AS 'NovoPreco'
FROM (SELECT productname,
price*0.8 AS 'precocomdesconto'
FROM products)AS ProdutosComDesconto
WHERE precocomdesconto > 50
LIMIT 10;


/*10. (Subquery no WHERE, CONCAT): Liste os nomes dos produtos
concatenados com a sua unidade (Unit), mas apenas para produtos cujo
fornecedor (SupplierID) resida na cidade de 'London' (descubra o ID do
fornecedor via subquery na tabela Suppliers).*/

SELECT CONCAT(productname,' - ',Unit) AS 'NomeProduto e Unidade'
FROM products
WHERE supplierid IN (SELECT supplierid
FROM suppliers
WHERE city = 'London');

/*Bloco 2: Subqueries com Agrupamentos (GROUP BY, COUNT e SUBQUERY)
O foco aqui é usar subqueries que retornam listas (IN/ANY/ALL) ou agrupar dados
baseados em resultados de subconsultas.

11. (Subquery com IN, GROUP BY, COUNT): Agrupe as encomendas por
EmployeeID e conte-as, mas faça isso apenas para encomendas que
contêm o produto 'Chais' (descubra os OrderID via subquery em
OrderDetails e Products).*/

SELECT EmployeeID AS 'IDFuncionario',
COUNT(*) AS 'TotalEncomendas'
FROM orders
WHERE orderid IN (SELECT Orderid
FROM orderdetails
WHERE productid IN (SELECT productid
FROM products
WHERE productname = 'Chais'))
GROUP BY EmployeeID;

/*12. (Subquery no WHERE, GROUP BY, COUNT, LIMIT): Conte quantos clientes
existem por cidade, mas apenas para as cidades que também possuem
fornecedores (busque a lista de cidades únicas via subquery na tabela
Suppliers). Limite a 5 resultados.*/

SELECT customername AS 'NomeCliente',
COUNT(*) AS 'TotalClientes'
FROM customers
WHERE city IN (SELECT DISTINCT city
FROM suppliers)
GROUP BY City
LIMIT 5;


/*13. (Subquery com IN, GROUP BY, COUNT): Agrupe os detalhes de
encomendas (OrderDetails) por ProductID e conte quantas vezes foram
vendidos. Filtre a consulta principal para incluir apenas produtos da
categoria 'Beverages' (busque o CategoryID via subquery).*/

SELECT ProductID AS 'IDProduto',
COUNT(*) AS 'TotalVendas'
FROM orderdetails
WHERE productid IN (SELECT productid
FROM products
WHERE CategoryID = (SELECT CategoryID
FROM categories
WHERE categoryname = 'Beverages'))
GROUP BY productid;

/*14. (Subquery no FROM, GROUP BY, Cálculos): Crie uma subquery que liste
OrderID e o valor total em quantidade da encomenda. Na consulta
principal, agrupe por faixa de quantidade (ex: > 50) e conte quantas
encomendas se encaixam.*/

SELECT COUNT(*) AS 'TotalEncomendas'
FROM (SELECT orderid,
SUM(quantity)AS 'QuantidadeTotal'
FROM orderdetails
GROUP BY orderid) AS ResumoEncomendas
WHERE QuantidadeTotal > 50;

/*15. (Subquery correlacionada, GROUP BY, COUNT): Liste as categorias
(CategoryName) e conte os produtos, mas considere apenas produtos cujo
preço é superior à média de preço da sua própria categoria (subquery
correlacionada no WHERE). */
SELECT c.CategoryName as NomedaCategoria,
       COUNT(*) AS TotalProdutos
FROM Products p
JOIN Categories c ON p.CategoryID = c.CategoryID
WHERE p.Price > (
    SELECT AVG(p2.Price)
    FROM Products p2
    WHERE p2.CategoryID = p.CategoryID
)
GROUP BY c.CategoryName;

/*16. (Subquery no WHERE com EXISTS, GROUP BY, COUNT): Agrupe os
transportadores (ShipperID) na tabela Orders e conte as encomendas. Use
EXISTS com uma subquery para considerar apenas encomendas feitas no
ano de 1996. */
SELECT ShipperID, COUNT(*) AS TotalEncomendas
FROM Orders
GROUP BY ShipperID
HAVING EXISTS (
    SELECT 1
    FROM Orders o2
    WHERE YEAR(o2.OrderDate) = 1996
);

/*17. (Subquery no WHERE, GROUP BY, COUNT, LIMIT): Conte o número de
produtos oferecidos por cada fornecedor (SupplierID). Filtre apenas os
fornecedores que estão em países onde também existem clientes
(subquery em Customers). Limite a 10.*/
SELECT SupplierID, COUNT(*) AS TotalProdutos
FROM Products
WHERE SupplierID IN (
    SELECT SupplierID
    FROM Suppliers
    WHERE Country IN (
        SELECT DISTINCT Country
        FROM Customers
    )
)
GROUP BY SupplierID
LIMIT 10;

/*18. (Subquery no SELECT, GROUP BY): Agrupe os clientes por país e exiba o
país, seguido de uma subquery no SELECT que conte o número total de
encomendas (Orders) originadas desse país.*/
SELECT 
    c.Country AS Pais,
    COUNT(DISTINCT c.CustomerID) AS TotalClientes,
    (
        SELECT COUNT(*)
        FROM Orders o
        JOIN Customers c2 ON o.CustomerID = c2.CustomerID
        WHERE c2.Country = c.Country
    ) AS TotalEncomendas
FROM Customers c
GROUP BY c.Country;

/*19. (Subquery com IN, GROUP BY, Cálculos, LIMIT): Calcule a soma da
quantidade (Quantity) vendida por ProductID. Inclua apenas produtos cujo
preço seja superior a 20 euros (via subquery em Products). Limite aos 5
produtos mais vendidos.*/
SELECT ProductID AS IDdoProduto,
       SUM(Quantity) AS TotalVendidos
FROM OrderDetails
WHERE ProductID IN (
    SELECT ProductID
    FROM Products
    WHERE Price > 20
)
GROUP BY ProductID
ORDER BY TotalVendidos DESC
LIMIT 5;

/*20. (Subquery no FROM, GROUP BY, COUNT): Faça uma subquery que
selecione os clientes que fizeram mais de 3 encomendas. Na consulta
principal, conte de quais cidades vêm esses clientes "VIP".*/
SELECT c.City,
       COUNT(*) AS TotalClientesVIP
FROM (
    SELECT CustomerID, City
    FROM Customers
    WHERE CustomerID IN (
        SELECT CustomerID
        FROM Orders
        GROUP BY CustomerID
        HAVING COUNT(*) > 3
    )
) c
GROUP BY c.City;

/*Bloco 3: Filtros Avançados pós-Agrupamento (HAVING e SUBQUERY)
A dificuldade aumenta: a subconsulta é utilizada dentro da cláusula HAVING para
validar agregações dinâmicas.

21. (GROUP BY, HAVING com Subquery, COUNT): Agrupe as encomendas por
EmployeeID e conte-as. Mostre apenas os funcionários cuja contagem de
encomendas seja superior à média de encomendas processadas por todos
os funcionários (subquery no HAVING).*/
SELECT EmployeeID,
       COUNT(*) AS TotalEncomendas
FROM Orders
GROUP BY EmployeeID
HAVING COUNT(*) > (
    SELECT AVG(NumEncomendas)
    FROM (
        SELECT COUNT(*) AS NumEncomendas
        FROM Orders
        GROUP BY EmployeeID
    ) t
);

/*22. (GROUP BY, HAVING com Subquery, CONCAT): Agrupe os produtos por
CategoryID e concatene os nomes das categorias. Use HAVING para
mostrar apenas categorias onde o preço médio dos produtos é maior que o
preço médio do sistema inteiro.).*/
SELECT CategoryID,
       GROUP_CONCAT(ProductName) AS Produtos
FROM Products
GROUP BY CategoryID
HAVING AVG(Price) > (
    SELECT AVG(Price)
    FROM Products
);

/*23. (GROUP BY, HAVING com Subquery, COUNT): Conte os clientes por país.
Exiba apenas os países (HAVING) onde a quantidade de clientes é igual ao
número de clientes que vivem no 'USA' (obtenha este número via
subquery).*/
SELECT Country,
       COUNT(*) AS TotalClientes
FROM Customers
GROUP BY Country
HAVING COUNT(*) = (
    SELECT COUNT(*)
    FROM Customers
    WHERE Country = 'USA'
);

/*24. (GROUP BY, HAVING com Subquery, Cálculos): Agrupe OrderDetails por
OrderID e calcule a quantidade total. Mostre apenas as encomendas cuja
quantidade total é superior à quantidade máxima faturada numa única
linha de OrderDetails de todo o histórico.*/
SELECT OrderID,
       SUM(Quantity) AS TotalQuantidade
FROM OrderDetails
GROUP BY OrderID
HAVING SUM(Quantity) > (
    SELECT MAX(QuantidadeLinha)
    FROM (
        SELECT Quantity AS QuantidadeLinha
        FROM OrderDetails
    ) t
);

/*25. (GROUP BY, HAVING com Subquery com ALL): Agrupe os produtos por
fornecedor e conte-os. Use HAVING para mostrar apenas os fornecedores
cuja contagem de produtos seja superior à contagem de produtos de
TODOS os fornecedores do país 'UK' (subquery com ALL).*/
SELECT SupplierID,
       COUNT(*) AS TotalProdutos
FROM Products
GROUP BY SupplierID
HAVING COUNT(*) > ALL (
    SELECT COUNT(*)
    FROM Products p
    JOIN Suppliers s ON p.SupplierID = s.SupplierID
    WHERE s.Country = 'UK'
    GROUP BY p.SupplierID
);

/* 26. (GROUP BY, HAVING com Subquery, COUNT, LIMIT): Agrupe as
encomendas pelo CustomerID e conte-as. Mostre apenas os clientes que
encomendaram mais vezes do que o cliente com ID 1. Limite a 5
resultados. */
SELECT CustomerID, COUNT(*) AS TOTALENCOMENDAS
FROM orders 
GROUP BY CustomerID
HAVING COUNT(*) > (
    SELECT COUNT(*)
    FROM Orders 
    WHERE customerID =1 
)
limit 5;

/*27. (GROUP BY, HAVING com Subquery, Cálculos): Agrupe os produtos pela
sua categoria e calcule o preço máximo em cada uma. Mostre apenas as
categorias cujo preço máximo seja inferior a 100 euros (validação via
subquery no HAVING, em vez de WHERE). */
SELECT CategoryID as categoria, MAX(price) as PrecoMaximo 
FROM Products
GROUP BY CategoryID
HAVING MAX(price) <(
    SELECT MAX(price)
    FROM Products 
    WHERE Price < 100 
);

/*28. (GROUP BY, COUNT, HAVING com EXISTS): Conte as encomendas por
EmployeeID. Mostre o resultado apenas se existir (via subquery EXISTS no
HAVING) alguma encomenda no sistema registada na data '1996-07-04'.*/
SELECT EmployeeID as IDdasEncomendas, COUNT(*) AS TotalEncomendas
FROM Orders
GROUP BY EmployeeID
HAVING EXISTS (
    SELECT 1
    FROM Orders 
    WHERE OrderDate = '1996-07-04'
);

/*29. (GROUP BY, HAVING com Subquery, Cálculos): Calcule a soma da
quantidade em OrderDetails agrupada por ProductID. Exiba apenas os
produtos cuja soma de vendas seja superior à soma de vendas do produto
'Tofu' (obtenha o ID e a soma via subquery).*/
SELECT ProductID AS IdDoProduto,
 SUM(Quantity) AS Quantidade
FROM OrderDetails
GROUP BY ProductID
HAVING ProductID = (
    SELECT ProductID
    FROM Products
    WHERE ProductName = 'tofu'
);

/*30. (GROUP BY, HAVING com Subquery escalar cruzada): Conte os
fornecedores por cidade. Mostre apenas as cidades cuja contagem seja
exatamente igual ao número total de transportadoras (Shippers) registadas
no banco (subquery simples no HAVING).*/
SELECT City AS Cidade,
	   COUNT(*) AS TOTALFORNECEDORES 
